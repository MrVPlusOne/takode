{
  "name": "the-companion",
  "version": "0.47.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "description": "Web UI for launching and interacting with Claude Code agents",
  "license": "MIT",
  "author": "The Vibe Company",
  "bin": {
    "the-companion": "./bin/cli.ts",
    "companion": "./bin/cli.ts",
    "memory": "./bin/memory.ts",
    "takode": "./bin/takode.ts",
    "stream": "./bin/stream.ts"
  },
  "files": [
    "bin/",
    "server/",
    "dist/"
  ],
  "engines": {
    "bun": ">=1.3.10"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agent",
    "web-ui",
    "vibe-coding"
  ],
  "scripts": {
    "dev": "bun --no-install dev.ts",
    "dev:api": "bun --no-install --watch server/index.ts",
    "dev:vite": "./node_modules/.bin/vite",
    "build": "./node_modules/.bin/vite build",
    "start": "NODE_ENV=production bun --no-install server/index.ts",
    "serve": "bun --no-install serve.ts",
    "prepublishOnly": "bun --no-install run build",
    "typecheck": "./scripts/typecheck.sh",
    "test": "./scripts/run-local-tool.sh vitest run --silent --reporter=verbose",
    "test:watch": "./scripts/run-local-tool.sh vitest",
    "test:codex-contract": "./scripts/run-local-tool.sh vitest run server/codex-protocol-*.test.ts",
    "check:staged-file-line-limit": "bun --no-install ./scripts/check-staged-file-line-limit.ts",
    "format": "./node_modules/.bin/biome format --write .",
    "format:check": "./node_modules/.bin/biome format ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.141",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "croner": "10.0.1",
    "diff": "8.0.4",
    "highlight.js": "11.11.1",
    "hono": "4.12.18",
    "sharp": "0.34.5",
    "shell-quote": "1.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.13",
    "@types/diff": "8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/shell-quote": "1.7.5",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "4.1.5",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "autoprefixer": "10.5.0",
    "jsdom": "28.1.0",
    "postcss": "8.5.14",
    "react": "19.2.6",
    "react-arborist": "3.5.0",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.11.0",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vitest": "4.1.5",
    "zustand": "5.0.13"
  }
}
